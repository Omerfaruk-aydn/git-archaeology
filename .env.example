# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gitarchaeology

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# App
DEBUG=true
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
DEFAULT_LLM_PROVIDER=openai

# ── OpenAI ───────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1

# ── Anthropic ────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ── Google Gemini ────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# ── Azure OpenAI ────────────────────────────────────────
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_MODEL=gpt-4o

# ── AWS Bedrock ──────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_BEDROCK_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0

# ── OpenRouter ──────────────────────────────────────────
OPENROUTER_API_KEY=your-openrouter-key
OPENROUTER_MODEL=openai/gpt-4o

# ── Together AI ─────────────────────────────────────────
TOGETHER_API_KEY=your-together-key
TOGETHER_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct-Turbo

# ── Groq ────────────────────────────────────────────────
GROQ_API_KEY=your-groq-key
GROQ_MODEL=llama-3.3-70b-versatile

# ── Mistral AI ──────────────────────────────────────────
MISTRAL_API_KEY=your-mistral-key
MISTRAL_MODEL=mistral-large-latest

# ── Cohere ──────────────────────────────────────────────
COHERE_API_KEY=your-cohere-key
COHERE_MODEL=command-r-plus-08-2024

# ── DeepSeek ────────────────────────────────────────────
DEEPSEEK_API_KEY=your-deepseek-key
DEEPSEEK_MODEL=deepseek-chat

# ── xAI (Grok) ─────────────────────────────────────────
XAI_API_KEY=your-xai-key
XAI_MODEL=grok-2

# ── Fireworks AI ────────────────────────────────────────
FIREWORKS_API_KEY=your-fireworks-key
FIREWORKS_MODEL=accounts/fireworks/models/llama-v3p1-70b-instruct

# ── Hugging Face ────────────────────────────────────────
HF_TOKEN=your-hf-token
HF_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct

# ── Replicate ───────────────────────────────────────────
REPLICATE_API_TOKEN=your-replicate-token
REPLICATE_MODEL=meta/meta-llama-3-70b-instruct

# ── Baidu Qianfan (ERNIE) ──────────────────────────────
QIANFAN_ACCESS_KEY=your-qianfan-access-key
QIANFAN_SECRET_KEY=your-qianfan-secret-key
QIANFAN_MODEL=ERNIE-4.0-8K

# ── Alibaba DashScope (Qwen) ───────────────────────────
DASHSCOPE_API_KEY=your-dashscope-key
DASHSCOPE_MODEL=qwen-plus

# ── Moonshot (Kimi) ─────────────────────────────────────
MOONSHOT_API_KEY=your-moonshot-key
MOONSHOT_MODEL=moonshot-v1-8k

# ── Zhipu AI (GLM) ─────────────────────────────────────
ZHIPUAI_API_KEY=your-zhipuai-key
ZHIPUAI_MODEL=glm-4

# ── MiniMax ─────────────────────────────────────────────
MINIMAX_API_KEY=your-minimax-key
MINIMAX_MODEL=MiniMax-Text-01

# ── DeepInfra ───────────────────────────────────────────
DEEPINFRA_API_KEY=your-deepinfra-key
DEEPINFRA_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct

# ── Perplexity ──────────────────────────────────────────
PERPLEXITY_API_KEY=your-perplexity-key
PERPLEXITY_MODEL=sonar-pro

# ── Cloudflare Workers AI ───────────────────────────────
CLOUDFLARE_API_TOKEN=your-cloudflare-token
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_MODEL=@cf/meta/llama-3.1-8b-instruct

# ── Local LLM (Ollama / vLLM / LM Studio) ──────────────
LOCAL_LLM_URL=http://localhost:11434
LOCAL_LLM_MODEL=llama3
